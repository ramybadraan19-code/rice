            "class<[Tt]hunderbird|[Tt]hunderbird-esr>": "´ì░ ",
            "class<eu.betterbird.Betterbird>": "´ì░ ",
            "title<.*gmail.*>": "¾░è½ ",

            "class<[Tt]elegram-desktop|org.telegram.desktop|io.github.tdesktop_x64.TDesktop>": "¯êù ",
            "class<discord|[Ww]ebcord|Vesktop>": "´ç┐ ",
            "title<.*whatsapp.*>": "´ê▓ ",
        "title<.*zapzap.*>": "´ê▓ ",
            "title<.*messenger.*>": "´ëƒ ",
            "title<.*facebook.*>": "´éÜ ",
            "title<.*instagram.*>": "¾░ï¥ ",
            "title<.*reddit.*>": "´èü ",


            "title<.*ChatGPT.*>": "¾░Ü® ",
            "title<.*deepseek.*>": "¾░Ü® ",
            "title<.*qwen.*>": "¾░Ü® ",
            "class<subl>": "¾░à│ ",
            "class<slack>": "´åÿ ",

            "class<mpv>": "´ì« ",
            "class<celluloid|Zoom>": "´Ç¢ ",
            "class<Cider>": "¾░Äå ",
            "title<.*Picture-in-Picture.*>": "´ö¼ ",
            "title<.*youtube.*>": "´à¬ ",
            "class<vlc>": "¾░ò╝ ",
            "title<.*cmus.*>": "´Çü ",
            "class<[Ss]potify>": "´å╝ ",

            "class<virt-manager>": "¯¡╗ ",
            "class<.virt-manager-wrapped>": "¯¡╗ ",
            "class<virtualbox manager>": "­ƒÆ¢ ",
            "title<virtualbox>": "­ƒÆ¢ ",
            "class<remmina>": "­ƒûÑ´©Å ",

            "class<VSCode|code-url-handler|code-oss|codium|codium-url-handler|VSCodium|code>": "¾░¿× ",
        "class<dev.zed.Zed>": "¾░Áü",
            "class<codeblocks>": "¾░à® ",
            "title<.*github.*>": "´äô ",
            "class<mousepad>": "´à£ ",
            "class<libreoffice-writer>": "¯ÜÑ ",
            "class<libreoffice-startcenter>": "¾░Åå ",
            "class<libreoffice-calc>": "´ì╗ ",
            "title<.*nvim ~.*>": "´ì» ",
            "title<.*vim.*>": "¯ƒà ",
            "title<.*nvim.*>": "¯ƒà ",
            "title<.*figma.*>": "¯¢ç ",
            "title<.*jira.*>": "¯Ø£ ",
            "class<jetbrains-idea>": "¯×Á ",

            "class<obs|com.obsproject.Studio>": "¯«º ",

            "class<polkit-gnome-authentication-agent-1>": "¾░Æâ ",
            "class<nwg-look>": "¯¡Æ ",
            "class<[Pp]avucontrol|org.pulseaudio.pavucontrol>": "¾▒í½ ",
            "class<steam>": "´åÂ ",
            "class<thunar|nemo>": "¾░Ø░ ",	
        "class<Gparted>":"´âç",
            "class<gimp>": "´î© ",
            "class<emulator>": "­ƒô▒ ",
            "class<android-studio>": "´à╗ ",
        "class<org.pipewire.Helvum>": "¾░ôâ",
        "class<localsend>":"´çá",
        "class<PrusaSlicer|UltiMaker-Cura|OrcaSlicer>": "¾░╣ø",
            }
    },

    // cpu
    "cpu": {
        "interval": 10,
        "format": "{icon0}{icon1}{icon2}{icon3}{icon4} {usage}%",
        "format-icons": ["Ôûü", "Ôûé", "Ôûâ", "Ôûä", "Ôûà", "Ôûå", "Ôûç", "Ôûê"]
    },

    // memory
    "memory": {
        "interval": 2,
        "format": "¾░¥à {percentage}%",
        "max-length": 10,
        "tooltip": true,
        "tooltip-format": "¯ëª {used:0.1f}GB/{total:0.1f}GB ({percentage}%)"
    },

    // dik
    "disk": {
        "interval": 30,
        "format": "´âç {free}",
        "path": "/",
        "tooltip": true,
        "tooltip-format": "Storage - {used} used out of {total} on {path} ({percentage_used}%)"
    },

    // temperature
    "temperature": {
        "thermal-zone": 2,
        "format": "´ïë {temperatureC}┬░C",
        "critical-threshold": 70,
        "format-critical": "´ïç {temperatureF}┬░F",
        "on-click": "kitty --title btop sh -c 'btop'"
    },
    
    // backlight
    "backlight": {
        "interval": 2,
        "align": 0,
        "rotate": 0,
        "format": "{icon} {percent}%",
        "format-icons": [
            "¯Åò ",
            "¯Åù ",
            "¯ÅÜ ",
            "¾░âØ ",
            "¾░â× ",
            "¾░âƒ ",
            "¾░âá "
        ],
        "tooltip-format": "backlight {percent}%",
        "icon-size": 10,
        "on-click": "",
        "on-click-middle": "",
        "on-click-right": "",
        "on-update": "",
        "on-scroll-up": "~/.config/hypr/scripts/brightness.sh up",
        "on-scroll-down": "~/.config/hypr/scripts/brightness.sh down",
        "smooth-scrolling-threshold": 1
    },

    // tray
    "tray": {
        "icon-size": 18,
        "spacing": 10
    },

    // clock
    "clock": {
        "format": "´Çù {:%I:%M %p}",
        "format-alt": "´Çù {:%R ¾░â¡ %d┬À%m┬À%Y}",
        "on-clock-right": "exec gnome-calendar",
        "tooltip": true,
        "tooltip-format": "<span>{calendar}</span>",
        "calendar": {
            "mode": "month",
            "mode-mon-col": 3,
            "on-scroll": 1,
            "on-click-right": "mode",
            "format": {
                "months": "<span color='#ffead3'><b>{}</b></span>",
                "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
                "today": "<span color='#ff6699'><b>{}</b></span>"
            }
        },
        "actions": {
            "on-click-right": "mode",
            "on-click-forward": "tz_up",
            "on-click-backward": "tz_down",
            "on-scroll-up": "shift_down",
            "on-scroll-down": "shift_up"
        }
    },

    // battery
    "battery": {
	//"interval": 5,
	"align": 0,
	"rotate": 0,
	"full-at": 100,
	"design-capacity": false,
	"states": {
		"good": 95,
		"warning": 30,
		"critical": 15
	},
	"format": "{icon} {capacity}%",
	"format-charging": "´âº {capacity}%",
	"format-plugged": "¾▒ÿû {capacity}%",
	"format-alt-click": "click",
	"format-full": "{icon} Full",
	"format-alt": "{icon} {time}",
	"format-icons": [
		"¾░éÄ", "¾░ü║", "¾░ü╗", "¾░ü╝", "¾░ü¢", "¾░ü¥", "¾░ü┐", "¾░éÇ", "¾░éü", "¾░éé", "¾░ü╣"
	    ],
	"format-time": "{H}h {M}min",
	"tooltip": true,
	"tooltip-format": "{timeTo} {power}w",
    },

    "pulseaudio/slider": {
        "min": 0,
        "max": 100,
        "on-scroll-up": "~/.config/hypr/scripts/volumecontrol.sh --inc",
        "on-scroll-down": "~/.config/hypr/scripts/volumecontrol.sh --dec",
        "orientation": "vertical"
    },

    // pulseaudio
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "´æª ",
        "tooltip": false,
        "on-click": "~/.config/hypr/scripts/volumecontrol.sh --toggle",
        "on-click-right": "pavucontrol",
        "on-scroll-up": "~/.config/hypr/scripts/volumecontrol.sh --inc",
        "on-scroll-down": "~/.config/hypr/scripts/volumecontrol.sh --dec",
        "scroll-step": 5,
        "format-icons": {
            "headphone": "´ÇÑ",
            "hands-free": "´ÇÑ",
            "headset": "´ÇÑ",
            "phone": "´éò",
            "default": ["´Çª", "´Çº", "´Ç¿ "]
        }
    },

    // pulseautio mic
    "pulseaudio#microphone": {
        "format": "{format_source}",
        "format-source": "´ä░ {volume}%",
        "format-source-muted": "´ä▒",
        "on-click": "pamixer --default-source -t",
        "on-click-right": "pavucontrol",
        "on-scroll-up": "pamixer --default-source -i 5",
        "on-scroll-down": "pamixer --default-source -d 5",
        "scroll-step": 5
    },

    // mpris ( media player )
    "mpris": {
        "interval": 2,
        "format": "{player_icon}  {status_icon}",
        "format-paused": "{player_icon}  {status_icon}",
        "tooltip": true,
        "tooltip-format": "{dynamic}",
        "on-click": "playerctl play-pause",
        "on-click-middle": "playerctl previous",
        "on-click-right": "playerctl next",
        "scroll-step": 5.0,
        "on-scroll-up": "~/.config/hypr/scripts/volumecontrol.sh --inc",
        "on-scroll-down": "~/.config/hypr/scripts/volumecontrol.sh --dec",
        "smooth-scrolling-threshold": 1,
        "player-icons": {
            "chromium": "´ë¿",
            "default": "´ÇØ",
            "firefox": "´ë®",
            "kdeconnect": "´ÿƒ",
            "mopidy": "´Çü",
            "mpv": "¾░É╣",
            "spotify": "´å╝",
            "vlc": "¾░ò╝"
        },
        "status-icons": {
            "paused": "¾░Åñ ",
            "playing": "´üï ",
            "stopped": "´üì"
        },
        "max-length": 30
    },

    "power-profiles-daemon": {
      "format": "{icon}",
      "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
      "tooltip": true,
      "format-icons": {
        "default": "´âº",
        "performance": "´âº",
        "balanced": "´ëÄ",
        "power-saver": "´ü¼"
      }
    },

