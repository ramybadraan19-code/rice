{
    "label" : "lock",
    "action": "$HOME/.config/hypr/scripts/power.sh --lock",
    "text" : "LOCK",
    "keybind" : "l"
}
{
    "label" : "logout",
    "action": "$HOME/.config/hypr/scripts/power.sh --logout",
    "text" : "LOGOUT",
    "keybind" : "e"
}
{
    "label" : "suspend",
    "action" : "systemctl suspend",
    "text" : "SUSPEND",
    "keybind" : "s"
}
{
    "label" : "hibernate",
    "action" : "systemctl hibernate",
    "text" : "HIBERNATE",
    "keybind" : "h"
}
{
    "label" : "shutdown",
    "action": "$HOME/.config/hypr/scripts/power.sh --poweroff",
    "text" : "SHUTDOWN",
    "keybind" : "u"
}
{
    "label" : "reboot",
    "action": "$HOME/.config/hypr/scripts/power.sh --reboot",
    "text" : "REBOOT",
    "keybind" : "r"
}
