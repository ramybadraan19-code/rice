    // network
    "network": {
        // "interface": "wlp2*", // (Optional) To force the use of this interface
        "format-wifi": "{icon}",
        "format-ethernet": "¾░îÿ",
        "tooltip-format": "Network: <big><b>{essid}</b></big>\nSignal strength: <b>{signaldBm}dBm ({signalStrength}%)</b>\nFrequency: <b>{frequency}MHz</b>\nInterface: <b>{ifname}</b>\nIP: <b>{ipaddr}/{cidr}</b>\nGateway: <b>{gwaddr}</b>\nNetmask: <b>{netmask}</b>",
        "format-linked": "¾░êÇ {ifname} (No IP)",
        "format-disconnected": "¾░û¬ ",
        "tooltip-format-disconnected": "Disconnected",
        "interval": 2,
        "max-length": 30,
    	"format-icons": [
    		"¾░ñ»", "¾░ñƒ", "¾░ñó", "¾░ñÑ", "¾░ñ¿"
    	],
        "on-click-right": "kitty -e nmtui"
    },

    // network speed
    "network#speed": {
        // "interface": "wlp2*", // (Optional) To force the use of this interface
        "format": "<span foreground='#99ffdd'>´ÇÖ {bandwidthDownBytes}</span> <span foreground='#ffcc66'>´éô {bandwidthUpBytes}</span>",
        "format-disconnected": "¾░û¬ ",
        "tooltip": false,
        "interval": 1,
        "max-length": 30,
    	"format-icons": [
    		"¾░ñ»", "¾░ñƒ", "¾░ñó", "¾░ñÑ", "¾░ñ¿"
    	],
        "on-click-right": "kitty -e nmtui"
    },

    // idle inhibitor
    "idle_inhibitor": {
        "format": "{icon}",
        "start-activated": true,
            "format-icons": {
                "activated": "¯░ò",
                "deactivated": "¾░øè"
            },
        "tooltip-format-activated":"Caffeine Mode: Active \nNothing will be happen.",
        "tooltip-format-deactivated":"Caffeine Mode: Inactive\n\nIf there is no interaction with your\nsystem (mouse/keyboard), then \nScreen Lock: after 5 min \nScreen Off: after 10 min \nSleep: after 30 min"
    },

    // window
    "hyprland/window": {
        "format": "{}",
        "separate-outputs": true,
        "rewrite": {
            "(.*)${USER}@${set_sysname}:(.*)": "$1 ´Æë :$2",
            "(.*) ÔÇö Mozilla Firefox": "$1 ¾░ê╣",
            "(.*)Mozilla Firefox": "$1 Firefox ¾░ê╣",
            "(.*) - Visual Studio Code": "$1 ¾░¿×",
            "(.*)Visual Studio Code": "$1 Code ¾░¿×",
            "(.*) ÔÇö Dolphin": "$1 ¾░ëï",
            "(.*)Spotify.*": "$1 Spotify ¾░ôç",
            "(.*)Steam": "$1 Steam ¾░ôô",
            "(.*) - Discord": "$1 ´ç┐ ",
            "(.*?)-\\s*YouTube(.*)": "$1¾░ùâ", 
            "(.*?\\s)YouTube(.*)": "$1YouTube ¾░ùâ"
        },
        "max-length": 50
    },

    // language
    "hyprland/language": {
        "interval": 1,
        "format": "¯®Ñ {}",
        "format-uk": "Uk",
        "format-en": "US"
    },

    // workspaces
    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "on-click": "activate",
        "on-scroll-up": "hyprctl dispatch workspace e-1",
        "on-scroll-down": "hyprctl dispatch workspace e+1",
        "format": "{icon}",
        // "format-icons": {
            // "1": "´äá",
            // "2": "´ë¿",
            // "3": "´äí",
            // "4": "´ü╗",
        //     "urgent": "´ü¬",
        //     "focused": "´åÆ",
        //     "default": "´äæ"
        // },
        "format-icons": {
            // for arch
            // "active": "¾░«»",
            // "default": "¯╗¥"

            // for fedora
            //  "active": "¾░úø",  
            //  "default": "´äî"

            // for opensuse
            // "active": "´îö",
            // "default": "¯¬»"
          },
        "persistent-workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": [],
            "5": []
        }
    },

    //------took it from JaKooLit-------//

    "hyprland/workspaces#preview": {
        "disable-scroll": true,
        "all-outputs": true,
        "warp-on-scroll": false,
        "sort-by-number": true,
        "show-special": false,
        "on-click": "activate",
        "on-scroll-up": "hyprctl dispatch workspace e+1",
        "on-scroll-down": "hyprctl dispatch workspace e-1",
        // "persistent-workspaces": {
        //     "*": 5
        //   },
        "persistent-workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": [],
            "5": []
        },
        "format": "{icon} {windows}",
        "format-window-separator": " ",
        "window-rewrite-default": "´üÖ ",
        "window-rewrite": {		
            "title<.*amazon.*>": "´ë░ ",
