{
    "include": [
        "$HOME/.config/waybar/modules/modules-main.jsonc",
        "$HOME/.config/waybar/modules/modules-groups.jsonc",
        "$HOME/.config/waybar/modules/modules-custom.jsonc",
    ],
    "layer": "top",
    "position": "top",
    "mod": "dock",
    "exclusive": true,
    "passthrough": false,
    "gtk-layer-shell": true,
    "reload_style_on_change": true,
    "height": 20,
    "margin-top": 5,
    "margin-left": 5,
    "margin-right": 5,

    "modules-left": [
        "custom/launch_rofi", 
        "tray", 
        "hyprland/workspaces#preview", 
        "custom/weather",
	"custom/notify",
	"power-profiles-daemon"
    ],

    "modules-center": [
        "mpris",
	"custom/cava",
	"clock"
    ],

    "modules-right": [
        "custom/updater", 
        "pulseaudio", 
        "pulseaudio#microphone", 
        "group/sysinfo", 
        "idle_inhibitor", 
        "custom/nightlight", 
        "custom/clipboard", 
        "battery", 
        "backlight",  
        "group/network", 
        "custom/power_btn"
    ],
}
